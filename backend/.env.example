# Führe folgende Schritte aus, um die KI-Extraktion zu aktivieren:
# 1. Kopiere diese Datei und nenne sie ".env" (also einfach nur .env)
# 2. Besorge dir einen kostenlosen Gemini API Key unter: https://aistudio.google.com/app/apikey
# 3. Trage den Key hier unten ein:

GEMINI_API_KEY="ein_api_key_hier"
